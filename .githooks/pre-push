#!/bin/sh

repo_root="$(git rev-parse --show-toplevel)"

if command -v pwsh >/dev/null 2>&1; then
  pwsh -NoProfile -ExecutionPolicy Bypass -File "$repo_root/scripts/repo-cleanup-before-push.ps1" -Apply
  exit $?
fi

if command -v powershell >/dev/null 2>&1; then
  powershell -NoProfile -ExecutionPolicy Bypass -File "$repo_root/scripts/repo-cleanup-before-push.ps1" -Apply
  exit $?
fi

echo "[REPO-CLEANUP] No PowerShell runtime available for pre-push cleanup gate."
exit 3
