# Build artifacts
/dist/**/WindowsOptimizer.exe
*.exe

# Runtime logs and telemetry
/logs/*.log
/logs/*.csv
/logs/health-audit-live.json

# dist runtime artifacts (overwritten each run, not source artifacts)
/dist/**/logs/*.json
/dist/**/logs/*.log
/dist/**/logs/*.csv
/dist/**/logs/diagnostics/

# Local module cache
/scripts/modules/
/dist/**/scripts/modules/

# Session and machine-specific artifacts
MANIFEST.txt
*.tmp
*.bak

# Potentially sensitive KB runtime journal
/KB/journal.md

# OS noise
Thumbs.db
.DS_Store
